# Environment Variables Template (Rename to .env)

# --- AI API Keys ---
# OpenAI, Anthropic, or Deepseek keys as needed by your chosen models
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
NVIDIA_API_KEY=
MODEL_ACCESS_KEY=

# --- Digital Ocean Spaces (S3 Compatible Storage) ---
# Used for saving chat metadata, message history, and user-uploaded images/media.
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_BUCKET=personal-intelligence
SPACES_REGION=nyc3

# --- Management ---
# Optional: Digital Ocean Personal Access Token for advanced infrastructure automation
DO_PAT=

# --- App Settings ---
NEXT_PUBLIC_API_URL=http://localhost:3000
